<h1>Pets#index</h1>
<p>Find me in app/views/pets/index.html.erb</p>

<% @pets.each do |pet| %>
    <%= link_to pet_path(pet) do %>
        <div class="p-3 mb-3 border w-25">
            <div><%= pet.name %></div>
            <div><%= pet.address %></div>
            <div><%= pet.species %></div>
            <div><%= pet.found_on %></div>
        </div>
    <% end %>
    <div><%= link_to "Delete Pet", pet_path(pet), data: {turbo_method: :delete, turbo_confirm: "Are you sure?"} %></div>
<% end %>